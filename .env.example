# OTDT Environment Variables (Copy to .env and fill from TechZone emails)
# Part 10 of Solo Build Guide

# Watson IoT Platform
WATSON_IOT_ORG_ID=
WATSON_IOT_DEVICE_TYPE=geothermal_turbine
WATSON_IOT_DEVICE_ID=GDC-TURBINE-01
WATSON_IOT_AUTH_TOKEN=
WATSON_IOT_API_KEY=
PUBLISH_INTERVAL_SECONDS=1

# IBM Maximo MAS 9.1
MAXIMO_MOCK_MODE=true                # Set to false when TechZone credentials available
MAXIMO_BASE_URL=https://<your-maximo-host>/maximo
MAXIMO_USERNAME=
MAXIMO_PASSWORD=
MAXIMO_SITE_ID=GDCKENYA

# watsonx.ai
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://eu-de.ml.cloud.ibm.com

# Red Hat OpenShift
OPENSHIFT_API_URL=
OPENSHIFT_TOKEN=

# TimescaleDB
TIMESCALEDB_URL=postgresql://postgres:password@localhost:5432/otdt

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_SENSORS=ot-twin-sensors

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
FAILURE_PROBABILITY_ALERT_THRESHOLD=0.25

# Monte Carlo
MC_ITERATIONS=10000

