WATSON_IOT_AUTH_TOKEN=
WATSON_IOT_API_KEY=
PUBLISH_INTERVAL_SECONDS=1

# IBM Maximo MAS 9.1 (from TechZone provisioning email)
MAXIMO_BASE_URL=
MAXIMO_USERNAME=
MAXIMO_PASSWORD=
MAXIMO_SITE_ID=GDCKENYA

# watsonx.ai (from TechZone watsonx.ai Sandbox provisioning email)
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://eu-de.ml.cloud.ibm.com

# Red Hat OpenShift (from TechZone OCP provisioning email)
OPENSHIFT_API_URL=
OPENSHIFT_TOKEN=

# TimescaleDB
TIMESCALEDB_URL=postgresql://postgres:password@localhost:5432/otdt

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_SENSORS=ot-twin-sensors

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
FAILURE_PROBABILITY_ALERT_THRESHOLD=0.25

# Monte Carlo
MC_ITERATIONS=10000

# Demo Configuration
DEMO_ASSET_ID=GDC-WP-007
ASSET_COUNT=50
SENSOR_FIELDS=temperature_c,pressure_bar,vibration_mm_s,flow_rate_kg_s,rotation_rpm,health_score,failure_label,failure_event